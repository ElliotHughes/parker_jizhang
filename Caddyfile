# 将 DOMAIN 替换为你的域名，如 jizhang.example.com
# 本地测试可改为 :80（不会自动申请 HTTPS）
{$DOMAIN:jz.99988800.xyz}

# 开启压缩
encode gzip zstd

# 后端 API 反向代理
handle /api/* {
    reverse_proxy api:3001
}

# 前端静态文件（SPA - 所有路由交给 index.html 处理）
handle {
    root * /srv/web
    try_files {path} /index.html
    file_server
}

# 日志
log {
    output stdout
    format console
}
